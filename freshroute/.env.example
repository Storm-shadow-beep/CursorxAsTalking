# FreshRoute API server
FRESHROUTE_PORT=3001

# Africa's Talking demo backend (run africastalking-demo-api-all on port 3000 first)
AT_BACKEND_URL=http://localhost:3000

# Pass-through to AT backend (.env in said-at project should hold real keys)
AFRICASTALKING_MOCK=false

# --- Credentials (copied from CursorxTalking/.env — also set these on the AT backend) ---
# FreshRoute proxies to the AT server; the AT project uses AT_USERNAME / AT_API_KEY.
# Copy the same values into: said-at/africastalking-demo-api-all/.env
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_sandbox_api_key

# AT backend variable names (same values as above)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key

# Server (AT backend only)
PORT=3000

# Optional AT backend
AT_FROM_SHORTCODE=12345
AT_SENDER_ID=
DEFAULT_RECIPIENT=+254700000000

# USSD and Voice (AT backend + voice escalation from FreshRoute)
AT_USSD_CODE=*384*123#
AT_VOICE_PHONE_NUMBER=+254711000000

# WhatsApp — REQUIRED for breakdown WhatsApp (set on AT backend .env)
# Your WhatsApp Business number from Africa's Talking dashboard (sender)
AT_WHATSAPP_SENDER=+2547XXXXXXXX
AT_WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_ENABLED=true

# Sandbox simulator: driver (USSD) + customer (receives breakdown SMS)
SANDBOX_DRIVER_PHONE=+255789123456
SANDBOX_BUYER_PHONE=+254700000001

# Dispatcher voice escalation target (FreshRoute)
DISPATCHER_PHONE=+254700000000

# Airtime reward when driver completes delivery (sandbox may cap amount)
AIRTIME_REWARD_AMOUNT=500
AIRTIME_CURRENCY=KES
# Set true to require USSD check-in (1) before airtime on complete (4)
AIRTIME_REQUIRES_CHECKIN=false
