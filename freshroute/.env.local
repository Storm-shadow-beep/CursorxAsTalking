# FreshRoute API server
FRESHROUTE_PORT=3001

# Africa's Talking demo backend (run africastalking-demo-api-all on port 3000 first)
AT_BACKEND_URL=http://localhost:3000

# Pass-through to AT backend (.env in said-at project should hold real keys)
AFRICASTALKING_MOCK=false

# --- Credentials (copied from CursorxTalking/.env — also set these on the AT backend) ---
# FreshRoute proxies to the AT server; the AT project uses AT_USERNAME / AT_API_KEY.
# Copy the same values into: said-at/africastalking-demo-api-all/.env
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=atsk_84564606253087900f1c0178575ddc4de3d7781bb87b1e63436ea1a08e7e40ab0f46c13c

# AT backend variable names (same values as above)
AT_USERNAME=sandbox
AT_API_KEY=your_sandbox_api_key

# Server (AT backend only)
PORT=3000

# Optional AT backend
AT_FROM_SHORTCODE=12345
AT_SENDER_ID=
DEFAULT_RECIPIENT=+255789123456

# USSD and Voice (AT backend + voice escalation from FreshRoute)
AT_USSD_CODE=*384*28480#
AT_VOICE_PHONE_NUMBER=+255789123456

# WhatsApp (AT backend — used when FreshRoute sends buyer updates)
AT_WHATSAPP_API_URL=
AT_WHATSAPP_SENDER=
AT_WHATSAPP_WEBHOOK_SECRET=

# Dispatcher voice escalation target (FreshRoute)
DISPATCHER_PHONE=+255789123456

# Default airtime reward (KES) on completed delivery with check-in
AIRTIME_REWARD_AMOUNT=10
AIRTIME_CURRENCY=KES
